# =============================================================================
# dev/.env — Langflow + AI service configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is loaded by docker compose via `env_file:` on the langflow service.
# The real .env is gitignored — never commit secrets.
# =============================================================================

# --- OpenAI -----------------------------------------------------------------
OPENAI_API_KEY=

# --- Opik (observability) ---------------------------------------------------
OPIK_API_KEY=
OPIK_URL_OVERRIDE=https://www.comet.com/opik/api
OPIK_PROJECT_NAME=LangflowIntercept
OPIK_WORKSPACE=

# --- Langflow feature flags -------------------------------------------------
LANGFLOW_API_KEY=dev-langflow-api-key
LANGFLOW_MCP_SERVER_ENABLED=false
LANGFLOW_ADD_PROJECTS_TO_MCP_SERVERS=false
