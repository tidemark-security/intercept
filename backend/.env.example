# Environment Configuration
DATABASE_URL=postgresql+asyncpg://intercept_user:intercept_password@localhost:5432/intercept_case_db

# Application Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO

# SMTP (for admin-issued password resets)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=dev-admin
SMTP_PASSWORD=dev-password
SMTP_USE_TLS=false
SMTP_FROM_ADDRESS=security-admin@example.com

# Session Management
SESSION_COOKIE_NAME=intercept_session
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS
SESSION_IDLE_TIMEOUT_HOURS=12
SESSION_SECRET_KEY=replace-with-long-random-value

# Object Storage Configuration (MinIO/S3)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=intercept-attachments
STORAGE_USE_SSL=false  # Set to true in production
STORAGE_REGION=us-east-1

# File Upload Validation
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain,application/json,text/csv,application/zip,application/x-7z-compressed,application/gzip,application/vnd.tcpdump.pcap
MAX_UPLOAD_SIZE_MB=50

# Presigned URL Expiration
UPLOAD_TIMEOUT_MINUTES=15
DOWNLOAD_TIMEOUT_MINUTES=30
