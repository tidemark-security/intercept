FROM node:24-slim

WORKDIR /app

# Copy UX library (referenced as file:../../ux in package.json)
COPY --from=ux . /ux

# Copy package files first for better layer caching
COPY package.json ./

# Install dependencies
RUN npm install

EXPOSE 5173

# Run development server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
