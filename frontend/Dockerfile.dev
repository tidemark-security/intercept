FROM node:24-slim

WORKDIR /app

RUN apt-get update \
	&& apt-get install -y --no-install-recommends git \
	&& rm -rf /var/lib/apt/lists/*

# Copy UX library build context
COPY --from=ux . /ux

# Copy package files first for better layer caching
COPY package.json ./

# Install dependencies
RUN npm pkg set dependencies.@tidemark-security/ux="file:/ux" \
	&& npm install

EXPOSE 5173

# Run development server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
