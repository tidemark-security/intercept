# =============================================================================
# Tidemark Intercept — Instance Configuration
# =============================================================================
# Copy to .env:  cp .env.example .env
#
# The quickstart installer (install.sh) generates this automatically.
# If setting up manually, generate secrets with:
#   openssl rand -base64 32 | tr -d '/+=' | head -c 24    (for passwords)
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  (for SECRET_KEY)
# =============================================================================

# --- Secrets (required) ------------------------------------------------------
POSTGRES_PASSWORD=<generate>
LANGFLOW_DB_PASSWORD=<generate>
SECRET_KEY=<generate-fernet-key>
MINIO_ROOT_USER=<generate>
MINIO_ROOT_PASSWORD=<generate>

# --- Langflow auth (required) ------------------------------------------------
LANGFLOW_SUPERUSER=admin
LANGFLOW_SUPERUSER_PASSWORD=<generate>
LANGFLOW_SECRET_KEY=<generate>
LANGFLOW_API_KEY=<generate>

# --- Image version (optional) ------------------------------------------------
# TAG=0.1.0

# --- AI features (optional) --------------------------------------------------
# Get an API key from https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# --- Opik observability (optional) -------------------------------------------
# OPIK_API_KEY=
# OPIK_URL_OVERRIDE=https://www.comet.com/opik/api
# OPIK_PROJECT_NAME=LangflowIntercept
# OPIK_WORKSPACE=
